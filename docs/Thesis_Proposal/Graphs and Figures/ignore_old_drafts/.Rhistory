# Y -> X
X1 ~ Y,
X12 ~ Y,
X123 ~ Y,
X1234 ~ Y,
X2 ~ Y,
X23 ~ Y,
X234 ~ Y,
X3 ~ Y ,
X34 ~ Y ,
X4 ~ Y,
# C1 layer
C1X1 ~ X1, C1X12 ~ X12, C1X123 ~ X123, C1X1234 ~ X1234,
C1X2 ~ X2, C1X23 ~ X23, C1X234 ~ X234, C1X3 ~ X3, C1X34 ~ X34, C1X4 ~ X4,
# C2 layer
C2X1 ~ X1, C2X12 ~ X12, C2X123 ~ X123, C2X1234 ~ X1234,
C2X2 ~ X2, C2X23 ~ X23, C2X234 ~ X234, C2X3 ~ X3, C2X34 ~ X34, C2X4 ~ X4,
# NEW C3 layer
C3X1 ~ X1, C3X12 ~ X12, C3X123 ~ X123, C3X1234 ~ X1234,
C3X2 ~ X2, C3X23 ~ X23, C3X234 ~ X234, C3X3 ~ X3, C3X34 ~ X34, C3X4 ~ X4,
exposure = "Y",
coords = list(
x = c(
# X’s
X1 = -2, X12 = -1.5, X123 = -1, X1234 = -0.5,
X2 = 0, Y = 0.5, X23 = 0.5, X234 = 1,
X3 = 1.5, X34 = 2, X4 = 2.5,
# C1
C1X1 = -2.25, C1X12 = -1.75, C1X123 = -1.25, C1X1234 = -0.75,
C1X2 = -0.25, C1X23 = 0.25, C1X234 = 0.75, C1X3 = 1.25, C1X34 = 1.75, C1X4 = 2.25,
# C2
