# C1 layer below
C1X1 = -1, C1X12 = -1, C1X123 = -1, C1X1234 = -1,
C1X2 = -1, C1X23 = -1, C1X234 = -1, C1X3 = -1, C1X34 = -1, C1X4 = -1,
# C2 further down
C2X1 = -2, C2X12 = -2, C2X123 = -2, C2X1234 = -2,
C2X2 = -2, C2X23 = -2, C2X234 = -2, C2X3 = -2, C2X34 = -2, C2X4 = -2,
# C3 even further down
C3X1 = -3, C3X12 = -3, C3X123 = -3, C3X1234 = -3,
C3X2 = -3, C3X23 = -3, C3X234 = -3, C3X3 = -3, C3X34 = -3, C3X4 = -3
)
)
)
ggdag(g)
library(dagitty)
library(ggdag)
X <- c("X1","X12","X123","X1234","X2","X23","X234","X3","X34","X4")
C_layers <- c("C1","C2","C3")
M_layers <- c("M1","M2")
# edges Y -> X
edges <- paste0(X, " ~ Y")
# edges C~X
for (cname in C_layers) {
edges <- c(edges, paste0(cname, X, " ~ ", X))
}
# edges M~C
for (cname in C_layers) {
for (x in X) {
for (m in M_layers) {
edges <- c(edges, paste0(cname, x, m, " ~ ", cname, x))
}
}
}
g <- dagify(!!!rlang::parse_exprs(edges), exposure = "Y")
library(dplyr)
library(tidyr)
library(ggplot2)
# Example: generate all combinations of choices
df <- expand.grid(
outcome = c("O1","O2","O3","O4"),
model   = c("logistic","cox","gee","log-binomial","mixed-logistic","dt-mixed"),
covars  = c("none","age","sex","age+sex","age+sex+BMI")
)
# reshape to long form for plotting
decisions <- df %>%
mutate(spec_id = row_number()) %>%
pivot_longer(-spec_id, names_to = "decision", values_to = "choice")
ggplot(decisions, aes(x = decision, y = factor(spec_id), fill = choice)) +
geom_tile() +
scale_fill_brewer(palette = "Set2") +
labs(x = "Decision step", y = "Planned specification") +
theme_minimal() +
theme(axis.text.y = element_blank(),
axis.ticks.y = element_blank())
library(ggalluvial)
install.packages("ggalluvial")
library(ggalluvial)
ggplot(df,
aes(axis1 = outcome, axis2 = model, axis3 = covars)) +
geom_alluvium(aes(fill = outcome), knot.pos = 0.3, alpha = .6) +
geom_stratum() +
geom_text(stat = "stratum", aes(label = after_stat(stratum))) +
scale_x_discrete(limits = c("Outcome", "Model", "Covariates")) +
theme_minimal()
