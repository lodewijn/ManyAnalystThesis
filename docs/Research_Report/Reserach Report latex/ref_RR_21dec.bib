@article{kummerfeld_one_2023,
	title = {One data set, many analysts: {Implications} for practicing scientists},
	volume = {14},
	issn = {1664-1078},
	shorttitle = {One data set, many analysts},
	url = {https://www.frontiersin.org/articles/10.3389/fpsyg.2023.1094150/full},
	doi = {10.3389/fpsyg.2023.1094150},
	abstract = {Researchers routinely face choices throughout the data analysis process. It is often opaque to readers how these choices are made, how they affect the findings, and whether or not data analysis results are unduly influenced by subjective decisions. This concern is spurring numerous investigations into the variability of data analysis results. The findings demonstrate that different teams analyzing the same data may reach different conclusions. This is the “many-analysts” problem. Previous research on the many-analysts problem focused on demonstrating its existence, without identifying specific practices for solving it. We address this gap by identifying three pitfalls that have contributed to the variability observed in many-analysts publications and providing suggestions on how to avoid them.},
	language = {en},
	urldate = {2025-09-26},
	journal = {Frontiers in Psychology},
	author = {Kummerfeld, Erich and Jones, Galin L.},
	month = feb,
	year = {2023},
	pages = {1094150},
	file = {PDF:/Users/loesjeubbink/Zotero/storage/8MLZ9LSV/Kummerfeld en Jones - 2023 - One data set, many analysts Implications for practicing scientists.pdf:application/pdf},
}

