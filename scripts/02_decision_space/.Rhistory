raw_groups <- list(
ever      = c("ph006d1", "ph006d4"),
age       = c("ph009_1", "ph009_4"),
recent    = c("ph0072_1", "ph0072_2", "ph067_1", "ph067_2"),
death     = c("xt011_")
)
group_combinations <- unlist(
lapply(1:length(raw_groups), function(k)
combn(names(raw_groups), k, simplify = FALSE)
),
recursive = FALSE
)
evaluate_outcome <- function(data, groups, raw_groups) {
raw_vars <- unlist(raw_groups[groups])
composite <- rowSums(data[raw_vars] == 1, na.rm = TRUE) > 0
as.integer(composite)
}
evaluate_outcome
