  pivot_longer(
    cols = starts_with("has_"),
    names_to = "confounder",
    values_to = "included"
  ) %>%
  mutate(confounder = gsub("has_", "", confounder) %>% str_to_title()) %>%
  ggplot(aes(x = confounder, y = RR, fill = included)) +
  geom_violin(alpha = 0.3, position = position_dodge(0.9)) +
