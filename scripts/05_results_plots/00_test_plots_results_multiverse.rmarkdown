#### MODEL TYPE PLOT #### 
```{r}
#### MODEL TYPE #### 
SM_colours <- gradient(length(unique(df_large$model_type)))

SM <- ggplot(df_large, aes(x = RR, colour = model_type)) +
  geom_density(linewidth = 0.8) +
  scale_colour_manual(values = alpha(SM_colours, 0.9)) +
  geom_vline(xintercept = 1, linetype = "dashed", colour = "black") +
  theme_minimal() + labs(y = "Density", title = "Statistical Model", caption = "Flat orange density is Cox PH, grey peaked density (most left) is log-binomial.") + theme(legend.position="none")

SM
```

#### ADJUSTMENT LABEL PLOT #### 
```{r}
#### ADJUSTMENT LABEL #### 
ADJ_colours <- gradient(length(unique(df_large$adjustment_label)))

ADJ <- ggplot(df_large, aes(x = RR, colour = adjustment_label)) +
  geom_density(linewidth = 0.8) +
  scale_colour_manual(values = alpha(ADJ_colours, 0.6)) +
  geom_vline(xintercept = 1, linetype = "dashed", colour = "black") +
  theme_minimal() + labs(y = "Density", title = "Adjustment Set", caption = "All orange densities include age as a confounder, all blue densities do not.") + theme(legend.position="none")

ADJ

# Create binary indicators for each confounder
df_adj <- df_large %>%
  mutate(
    has_none = grepl("none", adjustment_label, ignore.case = TRUE),
    has_age = grepl("age_int", adjustment_label, ignore.case = TRUE),
    has_sex = grepl("dn042_", adjustment_label, ignore.case = TRUE),
    has_country = grepl("country", adjustment_label, ignore.case = TRUE),
    has_smoking = grepl("br001_", adjustment_label, ignore.case = TRUE),
    has_education = grepl("dn010_", adjustment_label, ignore.case = TRUE),
    has_activity = grepl("phactiv", adjustment_label, ignore.case = TRUE)
  )

# Plot density for each confounder
dens_per_confounder <- df_adj %>%
  pivot_longer(
    cols = starts_with("has_"),
    names_to = "confounder",
    values_to = "included"
  ) %>%
  mutate(confounder = gsub("has_", "", confounder) %>% str_to_title()) %>%
  ggplot(aes(x = RR, colour = included)) +
  geom_density(alpha = 0.5) +
  geom_vline(xintercept = 1, linetype = "dashed") +
  facet_wrap(~ confounder, ncol = 3) +
  scale_colour_manual(
    name = "Confounder",
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    labels = c("TRUE" = "Included", "FALSE" = "Excluded")
  ) +
  labs(x = "RR", y = "Density", title = "Density plots of RR per adjustment variable",
    subtitle = "Each panel shows densities when including/excluding a specific adjustment variable",
    caption = "Note: Dashed line indicates RR = 1") +
  theme_minimal() +
  theme(legend.position = "bottom") + theme(
      plot.title = element_text(face = "bold", size = 18, hjust = 0.5),
      plot.subtitle = element_text(size = 14, hjust = 0.5),
      plot.caption = element_text(size = 11, hjust = 0)
    )

ECDF_per_confounder <- df_adj %>%
  pivot_longer(
    cols = starts_with("has_"),
    names_to = "confounder",
    values_to = "included"
  ) %>%
  mutate(confounder = gsub("has_", "", confounder) %>% str_to_title()) %>%
  ggplot(aes(x = RR, colour = included)) +
  stat_ecdf(linewidth = 0.8) +
  geom_vline(xintercept = 1, linetype = "dashed") +
  facet_wrap(~ confounder, ncol = 3) +
  scale_colour_manual(
    name = "Confounder",
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    labels = c("TRUE" = "Included", "FALSE" = "Excluded")
  ) +
  labs(x = "RR", y = "Density", title = "Empirical cumulative distribution functions (ECDF) of RRs per adjustment variable", subtitle = "Each panel shows ECDFs when including/excluding a specific adjustment variable") +
  theme_minimal() +
  theme(legend.position = "bottom")
```

### DENSITY GRID PLOT ###
```{r}
DensityGridPlot <- (DT | EC) / (MD | OUT) / (ADJ | SM) +
  plot_annotation(
    title = "Density plots of RR per analytical decision",
    subtitle = "Each panel shows densities across options of a specific decision",
    caption = "Note: Dashed line indicates RR = 1",
    theme = theme(
       plot.title = element_text(face = "bold", size = 18, hjust = 0.5),
      plot.subtitle = element_text(size = 14, hjust = 0.5),
      plot.caption = element_text(size = 11, hjust = 0)
    )
  )
```

### ECDF GRID PLOT ###
```{r}
DT_ECDF <- ggplot(df_large, aes(x = RR, colour = data_type)) +
  stat_ecdf(linewidth = 0.8) +
  theme_minimal() +   scale_colour_manual(values = alpha(DT_colours, 0.7)) +
  labs(x = "RR", y = "Cumulative probability", title = "Data Type") + theme(legend.position = "none")

EC_ECDF <- ggplot(df_large, aes(x = RR, colour = exclusion)) +
  stat_ecdf(linewidth = 0.8) +
  theme_minimal() +   scale_colour_manual(values = alpha(EC_colours, 0.7)) +
  labs(x = "RR", y = "Cumulative probability", title = "Exclusion") + theme(legend.position = "none")

MD_ECDF <- ggplot(df_large, aes(x = RR, colour = missing_data)) +
  stat_ecdf(linewidth = 0.8) +
  theme_minimal() +   scale_colour_manual(values = alpha(MD_colours, 0.7)) +
  labs(x = "RR", y = "Cumulative probability", title = "Missing Data") + theme(legend.position = "none")

OUT_ECDF <- ggplot(df_large, aes(x = RR, colour = outcome_label)) +
  stat_ecdf(linewidth = 0.8) +
  theme_minimal() +   scale_colour_manual(values = alpha(OUT_colours, 0.7)) +
  labs(x = "RR", y = "Cumulative probability", title = "Outcome") + theme(legend.position = "none")

ADJ_ECDF <- ggplot(df_large, aes(x = RR, colour = adjustment_label)) +
  stat_ecdf(linewidth = 0.8) +
  theme_minimal() +   scale_colour_manual(values = alpha(ADJ_colours, 0.7)) +
  labs(x = "RR", y = "Cumulative probability", title = "Adjustment Set", caption = "All orange PDFs include age as a confounder, all blue PDFs do not.") + theme(legend.position = "none")

SM_ECDF <- ggplot(df_large, aes(x = RR, colour = model_type)) +
  stat_ecdf(linewidth = 0.8) +
  theme_minimal() +   scale_colour_manual(values = alpha(SM_colours, 0.7)) +
  labs(x = "RR", y = "Cumulative probability", title = "Statistical Model", caption = "Most left (grey) is log-binom, most right (orange) is Cox PH.") + theme(legend.position = "none")


ECDFplot <- (DT_ECDF | EC_ECDF) / (MD_ECDF | OUT_ECDF) / (ADJ_ECDF | SM_ECDF) +
  plot_annotation(
    title = "Empirical cumulative distribution functions (ECDF) of RRs per analytical decision",
    subtitle = "Each panel shows ECDFs across decision options",
    theme = theme(
      plot.title = element_text(face = "bold", size = 18, hjust = 0.5),
      plot.subtitle = element_text(size = 14, hjust = 0.5),
      plot.caption = element_text(size = 11, hjust = 0)
    )
  )

ECDFplot
```

