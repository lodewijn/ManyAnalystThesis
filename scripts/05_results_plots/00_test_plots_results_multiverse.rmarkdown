---
title: "First Density Plots Results Multiverse"
date: today
format: pdf
---

#### SETUP ####
```{r}
# Load required packages
library(here)
library(tidyverse)
library(ggplot2)
library(cowplot)
library(specr)
library(dplyr)
library(tidyr)
library(patchwork)
library(kSamples)
```

```{r}
# Load data
df_small <- readRDS(here("data/results/all_models_final_results_1920_2026-04-15.RDS"))
df_large <- readRDS(here("data/results/corrected_results_final_2026-04-28.RDS"))

# Create color gradient function
gradient <- colorRampPalette(c("#D55E00", "#56B4E9"))
```

#### NAs ####
```{r}
# Replace Inf and 0.000 by NA
# as both indicate model non-convergence
df_large <- df_large %>%
  mutate(RR = ifelse(model_type == "GEE" & (RR == Inf | RR == 0), NA, RR),
         conf.low = ifelse(model_type == "GEE" & (conf.low == Inf | conf.low == 0), NA, conf.low),
         conf.high = ifelse(model_type == "GEE" & (conf.high == Inf | conf.high == 0), NA, conf.high))

# How many NAs?
df_large %>%
  summarise(na_count = sum(is.na(RR)))

# How are NAs distributed per decision?
df_large %>%
  group_by(model_type) %>%
  summarise(na_count = sum(is.na(RR)))

df_large %>%
  group_by(data_type) %>%
  summarise(na_count = sum(is.na(RR)))

df_large %>%
  group_by(outcome_label) %>%
  summarise(na_count = sum(is.na(RR)))

df_large %>%
  group_by(exclusion) %>%
  summarise(na_count = sum(is.na(RR)))

df_large %>%
  group_by(missing_data) %>%
  summarise(na_count = sum(is.na(RR)))

df_large <- df_large |>
  filter(!is.na(RR))
```

#### OUTCOME PLOT #### 
```{r}
#### OUTCOME #### 
OUT_colours <- gradient(length(unique(df_large$outcome_label)))

OUT <- ggplot(df_large, aes(x = RR, colour = outcome_label)) +
  geom_density(linewidth = 0.8) +
  scale_colour_manual(values = alpha(OUT_colours, 0.9)) +
  geom_vline(xintercept = 1, linetype = "dashed", colour = "black") +
  theme_minimal() + labs(y = "Density", title = "Outcome") + theme(legend.position="none")

OUT
```

