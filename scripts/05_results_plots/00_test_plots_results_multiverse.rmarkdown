### SPECIFICATION CURVE CLEANER WITH CI ###
```{r}
library(ggplot2)
library(dplyr)
library(tidyr)
library(cowplot)
library(stringr)

df_plot <- df_large %>%
  filter(!is.na(RR)) %>%
  arrange(RR) %>%
  mutate(
    spec_id = row_number(),
    significant = p.value < 0.05,
    adjustment_label = adjustment_label %>%
      str_replace_all("dn010_", "edu") %>%
      str_replace_all("dn042_", "sex") %>%
      str_replace_all("br001_", "smok") %>%
      str_replace_all("phactiv", "phys") %>%
      str_replace_all("country", "coun") %>%
      str_replace_all("age_int", "age") %>%
      str_replace_all("none", "none")
  )

choice_labels <- c(
  "data_type" = "Data Type",
  "missing_data" = "Missing Data",
  "exclusion" = "Exclusion",
  "outcome_label" = "Outcome",
  "model_type" = "Model",
  "adjustment_label" = "Adjustment Set"
)

# Set common x limits
x_limits <- c(0, max(df_plot$spec_id))

# Top panel: estimates with CIs
p_top <- ggplot(df_plot, aes(x = spec_id, y = RR, colour = significant)) +
  geom_linerange(
    aes(ymin = conf.low, ymax = conf.high),
    linewidth = 0.1, alpha = 0.1
  ) +
  geom_point(aes(color = significant),
               size = 0.5) +
  geom_hline(yintercept = 1, linetype = "dashed", colour = "black", linewidth = 0.3) +
  scale_colour_manual(
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    guide = "none"
  ) +
  scale_y_continuous(expand = c(0.02, 0)) +
  scale_x_continuous(expand = c(0.01, 0)) +
  theme_minimal()+
  theme(strip.text = element_blank(),
          axis.line = element_line("black", size = .3),
          legend.position = "none",
          panel.spacing = unit(1, "lines"),
          axis.text = element_text(colour = "black")) +
  labs(y = "Relative Risk", x = NULL)

# Bottom panel: specification grid
p_bottom <- df_plot %>%
  select(spec_id, data_type, missing_data, exclusion, outcome_label, model_type, adjustment_label, significant) %>%
  pivot_longer(
    cols = c(data_type, missing_data, exclusion, outcome_label, model_type, adjustment_label),
    names_to = "choice", 
    values_to = "value"
  ) %>%
  ggplot(aes(x = spec_id, y = value, colour = significant)) +
  geom_point(shape = 124,
               size = 2, alpha = 0.8) +
  scale_colour_manual(
    name = "p < 0.05",
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    labels = c("TRUE" = "Yes", "FALSE" = "No")
  ) +
  scale_x_continuous(limits = x_limits, expand = c(0, 0)) +
  facet_grid(choice ~ ., scales = "free_y", space = "free_y", switch = "y", 
             labeller = labeller(choice = choice_labels)) +
  theme_minimal() +
  theme(
    axis.line = element_line("black", size = .5),
    panel.spacing = unit(.75, "lines"),
    axis.text = element_text(colour = "black"),
    axis.text.y = element_text(size = 8),
    strip.text.y.left = element_text(angle = 0, hjust = 1, size = 10),
    strip.placement = "outside",
    plot.margin = margin(0, 10, 5, 10)
  ) +
  labs(x = "Specification", y = NULL)

# Combine
#plot_grid(p_top, p_bottom, ncol = 1, align = "v", axis = "lr", rel_heights = c(1, 5))
```

### FINAL SPECIFICATION CURVE CLEANER WITHOUT CI ###
```{r}
library(ggplot2)
library(dplyr)
library(tidyr)
library(cowplot)
library(stringr)

df_plot <- df_large %>%
  filter(!is.na(RR)) %>%
  arrange(RR) %>%
  mutate(
    spec_id = row_number(),
    significant = p.value < 0.05,
    
    # Adjustment labels
    adjustment_label = adjustment_label %>%
      str_replace_all("dn010_", "E") %>%
      str_replace_all("dn042_", "Se") %>%
      str_replace_all("br001_", "Sm") %>%
      str_replace_all("phactiv", "P") %>%
      str_replace_all("country", "C") %>%
      str_replace_all("age_int", "A") %>%
      str_replace_all("none", "N"),
    
    # Outcome labels
    outcome_label = outcome_label %>%
      str_replace_all("age_at_event", "Age") %>%
      str_replace_all("event_ever", "Ever") %>%
      str_replace_all("death_by_event", "Death") %>%
      str_replace_all("since_last_int", "Since"),
    
    # Data type labels
    data_type = data_type %>%
      str_replace_all("cross_all", "Cross-sectional (all)") %>%
      str_replace_all("cross_w1", "Cross-sectional (W1)") %>%
      str_replace_all("long_nostrict", "Longitudinal (no strict baseline)") %>%
      str_replace_all("long_w1", "Longitudinal (W1)"),
    
    # Missing data labels
    missing_data = missing_data %>%
      str_replace_all("cc", "Complete cases") %>%
      str_replace_all("ni", "No information"),
    
    # Exclusion labels
    exclusion = exclusion %>%
      str_replace_all("born_after1954", "Born after 1954") %>%
      str_replace_all("younger_than_55_w1", "Younger than 55") %>%
      str_replace_all("married_before18", "Married before 18") %>%
      str_replace_all("divorced_widowed", "Divorced/widowed") %>%
      str_replace_all("country", "Country") %>%
      str_replace_all("none", "None"),
    
    # Model type labels
    model_type = model_type %>%
      str_replace_all("cox_haz", "Cox PH") %>%
      str_replace_all("mix_log_reg", "Mixed logistic") %>%
      str_replace_all("log_reg", "Logistic") %>%
      str_replace_all("log-binom", "Log-binomial") %>%
      str_replace_all("time_mix", "Discrete-time mixed") %>%
      str_replace_all("GEE", "GEE")
  )

choice_labels <- c(
  "data_type" = "Data Type",
  "missing_data" = "Missing Data",
  "exclusion" = "Exclusion",
  "outcome_label" = "Outcome",
  "model_type" = "Statistical Model",
  "adjustment_label" = "Adjustment Set"
)

# Set common x limits
x_limits <- c(0, max(df_plot$spec_id))

# Top panel: estimates with CIs
p_top <- ggplot(df_plot, aes(x = spec_id, y = RR, colour = significant)) +
  geom_point(aes(color = significant),
               size = 0.5) +
  geom_hline(yintercept = 1, linetype = "dashed", colour = "black", linewidth = 0.3) +
  scale_colour_manual(
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    guide = "none"
  ) +
  scale_y_continuous(expand = c(0.02, 0)) +
  scale_x_continuous(expand = c(0.01, 0)) +
  theme_minimal()+
  theme(strip.text = element_blank(),
          axis.line = element_line("black", size = .3),
          legend.position = "none",
          panel.spacing = unit(1, "lines"),
          axis.text = element_text(colour = "black")) +
  labs(y = "Risk Ratio", x = NULL)

# Bottom panel: specification grid
p_bottom <- df_plot %>%
  select(spec_id, data_type, missing_data, exclusion, outcome_label, model_type, adjustment_label, significant) %>%
  pivot_longer( 
    cols = c(data_type, missing_data, exclusion, outcome_label, model_type, adjustment_label),
    names_to = "choice", 
    values_to = "value"
  ) %>%
  ggplot(aes(x = spec_id, y = value, colour = significant)) +
  geom_point(shape = 124,
               size = 2, alpha = 0.8) +
  scale_colour_manual(
    name = "p < 0.05",
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    labels = c("TRUE" = "Yes", "FALSE" = "No")
  ) +
  scale_x_continuous(limits = x_limits, expand = c(0, 0)) +
  facet_grid(choice ~ ., scales = "free_y", space = "free_y", switch = "y", 
             labeller = labeller(choice = choice_labels)) +
  theme_minimal() +
  theme(
    axis.line = element_line("black", size = .5),
    panel.spacing = unit(.75, "lines"),
    axis.text = element_text(colour = "black"),
    axis.text.y = element_text(size = 7),
    strip.text.y.left = element_text(angle = 90, hjust = 1, size = 11),
    strip.placement = "outside",
    plot.margin = margin(0, 10, 5, 10)
  ) +
  labs(x = "Specification", y = NULL)

# Combine
specPlot <- plot_grid(p_top, p_bottom, ncol = 1, align = "v", axis = "lr", rel_heights = c(1, 5))
```


## TEST SPEC CLEANER
```{r}
# ---- 1. Prep adjustment dot matrix ----
confounders <- c("Age", "Sex", "Smoking", "Education", "Country", "Physical activity")

df_adj_long <- df_plot %>%
  select(spec_id, adjustment_label, significant) %>%
  mutate(
    Age                 = str_detect(adjustment_label, regex("age", ignore_case = TRUE)),
    Country             = str_detect(adjustment_label, regex("country", ignore_case = TRUE)),
    Education           = str_detect(adjustment_label, regex("dn010_", ignore_case = TRUE)),
    None                = str_detect(adjustment_label, regex("none", ignore_case = TRUE)),
    `Physical activity` = str_detect(adjustment_label, regex("phactiv", ignore_case = TRUE)),
    Sex                 = str_detect(adjustment_label, regex("dn042_", ignore_case = TRUE)),
    Smoking             = str_detect(adjustment_label, regex("br001_", ignore_case = TRUE))
  ) %>%
  pivot_longer(
    cols = all_of(confounders),
    names_to = "confounder",
    values_to = "included"
  ) %>%
  mutate(
    confounder = factor(confounder, levels = rev(confounders)),
    panel = "Adjustment Set"
  )

# ---- 2. Prep outcome dot matrix ----
outcome_components <- c("Age", "Ever", "Death", "Since")

df_outcome_long <- df_plot %>%
  select(spec_id, outcome_label, significant) %>%
  mutate(
    Age   = str_detect(outcome_label, "Age"),
    Death = str_detect(outcome_label, "Death"),
    Ever  = str_detect(outcome_label, "Ever"),
    Since = str_detect(outcome_label, "Since")
  ) %>%
  pivot_longer(
    cols = all_of(outcome_components),
    names_to = "component",
    values_to = "included"
  ) %>%
  mutate(
    component = factor(component, levels = rev(outcome_components)),
    panel = "Outcome"
  )

# Replace strip_theme with this
strip_theme <- theme(
  axis.line.y = element_line("black", linewidth = 0.5),
  axis.line.x = element_blank(),
  axis.text = element_text(colour = "black"),
  axis.text.x = element_blank(),
  axis.ticks.x = element_blank(),
  axis.text.y = element_text(size = 8, hjust = 1),
  strip.text.y.left = element_text(angle = 0, hjust = 1, size = 10),
  strip.placement = "outside",
  legend.position = "none",
  panel.border = element_blank()  # removes box around panels
)

# ---- 3. Top panel ----
p_top <- ggplot(df_plot, aes(x = spec_id, y = RR, colour = significant)) +
  geom_point(size = 0.5) +
  geom_hline(yintercept = 1, linetype = "dashed", colour = "black", linewidth = 0.3) +
  scale_colour_manual(values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"), guide = "none") +
  scale_y_continuous(expand = c(0.02, 0)) +
  scale_x_continuous(expand = c(0.01, 0)) +
  theme_minimal() +
  theme(
    axis.line = element_line("black", linewidth = 0.3),
    axis.line.x.top = element_blank(),
    axis.text = element_text(colour = "black"),
    axis.text.x = element_blank(),
    axis.ticks.x = element_blank(),
    plot.margin = margin(5, 10, 0, 10)
  ) +
  labs(y = "Risk Ratio", x = NULL)

# ---- 4. Middle panel ----
p_bottom <- df_plot %>%
  select(spec_id, data_type, missing_data, exclusion, model_type, significant) %>%
  pivot_longer(
    cols = c(data_type, missing_data, exclusion, model_type),
    names_to = "choice", values_to = "value"
  ) %>%
  ggplot(aes(x = spec_id, y = value, colour = significant)) +
  geom_point(shape = 124, size = 2, alpha = 0.8) +
  scale_colour_manual(values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"), guide = "none") +
  scale_x_continuous(limits = x_limits, expand = c(0, 0)) +
  facet_grid(choice ~ ., scales = "free_y", space = "free_y", switch = "y",
             labeller = labeller(choice = choice_labels)) +
  theme_minimal() +
  strip_theme +
  theme(
    panel.spacing = unit(0.75, "lines"),
    plot.margin = margin(0, 10, 0, 10)
  ) +
  labs(x = NULL, y = NULL)

# ---- 5. Outcome panel ----
p_outcome <- ggplot(filter(df_outcome_long, included),
                    aes(x = spec_id, y = component, colour = significant)) +
  geom_point(shape = 124, size = 2, alpha = 0.8) +
  scale_colour_manual(values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"), guide = "none") +
  scale_x_continuous(limits = x_limits, expand = c(0, 0)) +
  scale_y_discrete(drop = FALSE) +
  facet_grid(panel ~ ., switch = "y") +
  theme_minimal() +
  strip_theme +
  theme(plot.margin = margin(0, 10, 0, 10)) +
  labs(x = NULL, y = NULL)

# ---- 6. Adjustment panel ----
p_adj <- ggplot(filter(df_adj_long, included),
                aes(x = spec_id, y = confounder, colour = significant)) +
  geom_point(shape = 124, size = 2, alpha = 0.8) +
  scale_colour_manual(
    name = "p < 0.05",
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    labels = c("TRUE" = "Yes", "FALSE" = "No")
  ) +
  scale_x_continuous(limits = x_limits, expand = c(0, 0)) +
  scale_y_discrete(drop = FALSE) +
  facet_grid(panel ~ ., switch = "y") +
  theme_minimal() +
  strip_theme +  # use shared theme now
  theme(
    axis.line.x.bottom = element_line("black", linewidth = 0.5),
    plot.margin = margin(0, 10, 5, 10),
    legend.position = "bottom",
    legend.direction = "horizontal",
    legend.title = element_text(size = 9),
    legend.text = element_text(size = 9)
  ) +
  labs(x = "Specification", y = NULL)

# ---- 7. Combine ----
specPlot <- plot_grid(
  p_top,
  p_bottom,
  p_outcome,
  p_adj,
  ncol = 1,
  align = "v",
  axis = "lr",
  rel_heights = c(1.5, 3.5, 0.8, 1.5)
)

specPlot
```








```{r}
df_plot <- df_large %>%
  filter(!is.na(RR)) %>%
  arrange(RR) %>%
  mutate(
    spec_id = row_number(),
    significant = p.value < 0.05,
    
    # Adjustment labels
    adjustment_label_abbrev = adjustment_label %>%
      str_replace_all("dn010_", "E") %>%
      str_replace_all("dn042_", "Se") %>%
      str_replace_all("br001_", "Sm") %>%
      str_replace_all("phactiv", "P") %>%
      str_replace_all("country", "C") %>%
      str_replace_all("age_int", "A") %>%
      str_replace_all("none", "N"), 
    
        # Outcome labels
    outcome_label = outcome_label %>%
      str_replace_all("age_at_event", "Age") %>%
      str_replace_all("event_ever", "Ever") %>%
      str_replace_all("death_by_event", "Death") %>%
      str_replace_all("since_last_int", "Since"),
    
    # Data type labels
    data_type = data_type %>%
      str_replace_all("cross_all", "Cross-sectional (all)") %>%
      str_replace_all("cross_w1", "Cross-sectional (W1)") %>%
      str_replace_all("long_nostrict", "Longitudinal (no strict baseline)") %>%
      str_replace_all("long_w1", "Longitudinal (W1)"),
    
    # Missing data labels
    missing_data = missing_data %>%
      str_replace_all("cc", "Complete cases") %>%
      str_replace_all("ni", "No information"),
    
    # Exclusion labels
    exclusion = exclusion %>%
      str_replace_all("born_after1954", "Born after 1954") %>%
      str_replace_all("younger_than_55_w1", "Younger than 55") %>%
      str_replace_all("married_before18", "Married before 18") %>%
      str_replace_all("divorced_widowed", "Divorced/widowed") %>%
      str_replace_all("country", "Country") %>%
      str_replace_all("none", "None"),
    
    # Model type labels
    model_type = model_type %>%
      str_replace_all("cox_haz", "Cox PH") %>%
      str_replace_all("mix_log_reg", "Mixed logistic") %>%
      str_replace_all("log_reg", "Logistic") %>%
      str_replace_all("log-binom", "Log-binomial") %>%
      str_replace_all("time_mix", "Discrete-time mixed") %>%
      str_replace_all("GEE", "GEE")
  )

choice_labels <- c(
  "data_type" = "Data Type",
  "missing_data" = "Missing Data",
  "exclusion" = "Exclusion",
  "outcome_label" = "Outcome",
  "model_type" = "Statistical Model",
  "adjustment_label" = "Adjustment Set"
)

# Top panel
p_top <- ggplot(df_plot, aes(x = spec_id, y = RR, colour = significant)) +
  geom_point(size = 0.5) +
  geom_hline(yintercept = 1, linetype = "dashed", colour = "black", linewidth = 0.3) +
  scale_colour_manual(
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    guide = "none"
  ) +
  scale_y_continuous(expand = c(0.02, 0)) +
  scale_x_continuous(expand = c(0.01, 0)) +
  theme_minimal() +
  theme(
    strip.text = element_blank(),
    axis.line = element_line("black", linewidth = 0.3),
    legend.position = "none",
    panel.spacing = unit(1, "lines"),
    axis.text = element_text(colour = "black"),
    plot.margin = margin(5, 10, 0, 10)
  ) +
  labs(y = "Risk Ratio", x = NULL)

# Bottom panel
p_bottom <- df_plot %>%
  select(spec_id, data_type, missing_data, exclusion, outcome_label, 
         model_type, adjustment_label_abbrev, significant) %>%
  pivot_longer(
    cols = c(data_type, missing_data, exclusion, outcome_label, 
             model_type, adjustment_label_abbrev),
    names_to = "choice",
    values_to = "value"
  ) %>%
  mutate(choice = recode(choice, adjustment_label_abbrev = "adjustment_label")) %>%
  ggplot(aes(x = spec_id, y = value, colour = significant)) +
  geom_point(shape = 124, size = 2, alpha = 0.8) +
  scale_colour_manual(
    name = "p < 0.05",
    values = c("TRUE" = "#56B4E9", "FALSE" = "#D55E00"),
    labels = c("TRUE" = "Yes", "FALSE" = "No")
  ) +
  scale_x_continuous(limits = x_limits, expand = c(0, 0)) +
  facet_grid(choice ~ ., scales = "free_y", space = "free_y", switch = "y",
             labeller = labeller(choice = choice_labels)) +
  theme_minimal() +
  theme(
    axis.line = element_line("black", linewidth = 0.5),
    panel.spacing = unit(0.75, "lines"),
    axis.text = element_text(colour = "black"),
    axis.text.y = element_text(size = 8, hjust = 1),  
    strip.text.y.left = element_text(angle = 90, hjust = 1, size = 11),
    strip.placement = "outside",
    plot.margin = margin(0, 80, 5, 10)  
  ) +
  labs(x = "Specification", y = NULL)

# Combine and save
specPlot <- plot_grid(p_top, p_bottom, ncol = 1, align = "v", 
                      axis = "lr", rel_heights = c(1.5, 5))

specPlot
```


